<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.CA2.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_16</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.CA2.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_16</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_16</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_16</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_16</item>
    </style>

    <style name="Widget.CA2.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_20</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/primary_light</item>
    </style>

</resources>
