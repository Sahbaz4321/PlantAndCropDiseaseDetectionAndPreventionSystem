<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CA2" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark color scheme (kept close to your palette) -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSecondaryContainer">@color/secondary_dark</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/text_primary</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/primary_light</item>

        <item name="materialButtonStyle">@style/Widget.CA2.Button</item>
        <item name="textInputStyle">@style/Widget.CA2.TextInputLayout</item>
        <item name="materialCardViewStyle">@style/Widget.CA2.Card</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>