<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:clipToPadding="false"
    android:paddingBottom="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Image Card with Menu Overlay -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="240dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="3dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_result_plant"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E2E8F0"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bottom_shadow_gradient" />

                <!-- Menu button moved here to save space -->
                <ImageButton
                    android:id="@+id/btnReportMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="16dp"
                    android:background="@drawable/circle_white_alpha"
                    android:contentDescription="Report Options"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/more"
                    app:tint="#1E293B" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_ai_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#E0E7FF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/loader_anim"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/loading_anim" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_ai_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI is analyzing..."
                        android:textColor="#4338CA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progress_ai"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:indeterminate="true"
                        android:progressTint="#4338CA" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Result Header -->
        <TextView
            android:id="@+id/tv_disease_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Disease Name"
            android:textColor="#1E293B"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Confidence Score Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/confidence_progress_circular"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/circular_progress_bar" />

                <TextView
                    android:id="@+id/tv_confidence_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0%"
                    android:textColor="#7B5CFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confidence Score"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_confidence_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Analyzing..."
                    android:textColor="#10B981"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.1"
            android:text="AI DIAGNOSIS REPORT"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Description - Justified Alignment -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeColor="#F1F5F9"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="#7B5CFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="start"
                    android:justificationMode="inter_word"
                    android:lineSpacingExtra="4sp"
                    android:text="Waiting for analysis..."
                    android:textColor="#334155"
                    android:textSize="15sp"
                    tools:targetApi="o" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Causes -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFF7ED"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Root Causes"
                    android:textColor="#EA580C"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_causes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:justificationMode="inter_word"
                    android:textColor="#9A3412"
                    android:textSize="14sp"
                    tools:targetApi="o" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Treatment -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F0FDF4"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Treatment Plan"
                    android:textColor="#16A34A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_treatment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:justificationMode="inter_word"
                    android:textColor="#14532D"
                    android:textSize="14sp"
                    tools:targetApi="o" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fertilizer -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#EFF6FF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recommended Fertilizer"
                    android:textColor="#2563EB"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_fertilizer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:justificationMode="inter_word"
                    android:textColor="#1E3A8A"
                    android:textSize="14sp"
                    tools:targetApi="o" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recovery Time -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_recovery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#F0FDFA"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated Recovery"
                    android:textColor="#0D9488"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="start"
                    android:justificationMode="inter_word"
                    android:textColor="#134E4A"
                    android:textSize="14sp"
                    tools:targetApi="o" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Prevention Section Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text="Prevention Tips"
            android:textColor="#DB2777"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Bullet Points for Prevention Tips -->
        <LinearLayout
            android:id="@+id/prevention_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_prevention_card"
            android:padding="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
